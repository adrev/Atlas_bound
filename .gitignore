# Dependencies
node_modules/
.venv/

# Build outputs
dist/
coverage/

# Database (regenerated on startup from Open5e API)
server/data/*.db
server/data/*.db-shm
server/data/*.db-wal

# Environment
.env
.env.local

# System
.DS_Store
*.log

# Stray build/script artifacts written to the repo root instead of client/.
# Root-anchored so they never touch the real client/public/ assets. The
# canonical asset copy lives in client/public/assets; a misrun script (and
# a `dev/null` git-hook write) drop partial copies here and show as dirty.
/public/
/dev/

# Claude temp
.claude/
scripts/__pycache__/
tmp-gemini-maps/
new-maps/

# Claude Design handoff screenshots (30MB of PNGs); HTML/JSX source is tracked
design-handoff/project/uploads/
