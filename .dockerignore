node_modules
*/node_modules
node_modules/
.git
.git/
.gitignore

# Build artifacts (we rebuild inside Docker)
shared/dist
server/dist
client/dist
dist/

# Development files
*.log
.env
.env.*
.env.local
.DS_Store

# Data (SQLite DB — created at runtime, synced to Turso)
server/data

# User-uploaded content is included in the build
# (prebuilt token/map images are in client/public/)

# Editor config
.vscode
.idea
*.swp
*.swo

# Secrets / tooling / temp dirs (match .gitignore)
.claude/
.venv/
tmp-gemini-maps/
new-maps/
scripts/__pycache__/
*.pyc

# Docs — exclude markdown from build context to shrink it and avoid
# leaking internal planning notes. README.md is kept for reference.
*.md
!README.md
