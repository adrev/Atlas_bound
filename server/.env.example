# Atlas Bound — Server Environment Variables
# Copy this to .env and fill in your credentials

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (https://developer.apple.com — requires paid dev account)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Turso Database (https://turso.tech — free tier)
# Leave empty for local SQLite-only mode
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Base URL for OAuth redirect callbacks
BASE_URL=http://localhost:5173

# CORS origins (comma-separated, add your domain for production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# Postgres / Cloud SQL
# Local dev commonly uses DATABASE_URL. Cloud Run uses PGPASSWORD plus
# CLOUD_SQL_CONNECTION_NAME, e.g. personal-project:us-central1:atlas-bound-db.
DATABASE_URL=
PGPASSWORD=
CLOUD_SQL_CONNECTION_NAME=

# Google Cloud / Vertex AI
# Optional on Cloud Run when metadata discovery works, explicit for local dev
# or when deploying from a different active gcloud project.
GCP_PROJECT_ID=
VERTEX_LOCATION=us-central1
CHRONICLER_MODEL=gemini-2.5-flash-lite

# Optional Chronicle worker mode
CHRONICLER_BACKEND=vertex
CHRONICLE_WORKER_TOKEN=

# Server port
PORT=3001
